# MEafterMe — Application Environment Variables
# Copy this file to .env.local for development
# For PRODUCTION: set these in cPanel → Node.js App Manager → Environment Variables

# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://afterme.life
APP_LOCALE_DEFAULT=en
APP_LOCALE_SECONDARY=bg
NODE_ENV=production
PORT=3000

# ── Session ──────────────────────────────────────────────────────────────────
# Must be at least 32 chars. Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-minimum-32-chars-long-secret-key!!

# ── Admin ────────────────────────────────────────────────────────────────────
# Protect the /admin panel and admin API routes
ADMIN_SECRET=change-me-to-a-strong-secret

# ── SMTP (SuperHosting domain email) ─────────────────────────────────────────
SMTP_HOST=mail.afterme.life
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@afterme.life
SMTP_PASS=your-mailbox-password
MAIL_FROM=MEafterMe <no-reply@afterme.life>

# ── Firebase Admin SDK (Firestore) ───────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY_B64 = base64 of the private_key from the service account JSON
# Generate with: echo -n "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n" | base64
FIREBASE_PRIVATE_KEY_B64=base64encodedprivatekey
