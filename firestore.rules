rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — any logged-in user can read; write only own document
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Answers — doc ID is always "{uid}_q{questionId}"
    // Rule: if the doc ID starts with the authenticated user's uid → allow
    match /answers/{answerId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    // Memories
    match /memories/{memoryId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Profile shares
    match /profile_shares/{shareId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // Deletion verification codes
    match /delete_codes/{codeId} {
      allow read, write, create: if request.auth != null;
    }

    // Avatar configs — own document only
    match /avatar_configs/{docId} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && request.auth.uid == resource.data.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Contact form
    match /contact_messages/{msgId} {
      allow create: if true;
    }

    // Vector index (written by Cloud Functions service account)
    match /vector_index/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // only Cloud Functions write here
    }
  }
}
