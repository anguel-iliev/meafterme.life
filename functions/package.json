{
  "name": "meafterme-functions",
  "version": "1.0.0",
  "description": "MEafterMe Firebase Cloud Functions — RAG pipeline",
  "main": "lib/index.js",
  "scripts": {
    "build":   "tsc",
    "watch":   "tsc --watch",
    "serve":   "npm run build && firebase emulators:start --only functions",
    "deploy":  "npm run build && firebase deploy --only functions",
    "logs":    "firebase functions:log"
  },
  "engines": { "node": "20" },
  "dependencies": {
    "firebase-admin":    "^13.0.0",
    "firebase-functions": "^6.0.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "openai":            "^4.52.0",
    "pdf-parse":         "^1.1.1",
    "mammoth":           "^1.8.0",
    "axios":             "^1.7.0"
  },
  "devDependencies": {
    "typescript":              "^5.5.0",
    "@types/node":             "^20.0.0",
    "firebase-functions-test": "^3.3.0"
  },
  "private": true
}
