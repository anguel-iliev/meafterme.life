rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User memory files — owner only
    match /memories/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Avatar audio files generated by Cloud Functions — allow public read
    // (used by D-ID API which has no Firebase auth)
    match /avatar_audio/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Avatar photos — allow public read so D-ID can access them
    match /avatar_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
